PORT=3001
NODE_ENV=development

# Local MySQL (MySQL Workbench) — apne existing MySQL credentials yahan daalen
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=employee_management

JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=8h

CORS_ORIGIN=http://localhost:3000

# Default admin users seeded on first startup
ADMIN_EMAIL=admin@ems.local
ADMIN_PASSWORD=
SUPER_EMAIL=superadmin@ems.online
SUPER_PASSWORD=

# Set to true to auto-seed demo employees + 2025/2026 payrolls on startup
# Or run once: npm run seed:demo
SEED_DEMO_DATA=false
