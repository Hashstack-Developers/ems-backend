PORT=3001
NODE_ENV=development

# Local MySQL (MySQL Workbench) — apne existing MySQL credentials yahan daalen
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=employee_management

JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=8h

CORS_ORIGIN=http://localhost:3000

# Default admin users seeded on first startup
ADMIN_EMAIL=admin@ems.local
ADMIN_PASSWORD=
SUPER_EMAIL=superadmin@ems.online
SUPER_PASSWORD=

# Auto-generate payrolls when employee is created
AUTO_GENERATE_PAYROLLS=true

# ---------------------------------------------------------------------------
# Email — salary slip PDFs sent automatically when payroll is generated
# Leave MAIL_USER and MAIL_PASS empty to disable email sending entirely
# ---------------------------------------------------------------------------
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Create an app password (select "Mail" + "Windows Computer" or "Other")
#   4. Paste the 16-character app password below (no spaces)
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM_NAME=EMS Payroll
